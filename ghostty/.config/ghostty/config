# Ghostty Terminal Configuration
# Modern, GPU-accelerated terminal

# Theme
theme = Catppuccin Macchiato
background = #24273a
foreground = #cad3f5
cursor-color = #f4dbd6
selection-background = #5b6078
selection-foreground = #cad3f5

# Font
# Use a Nerd Font directly so tmux/powerline glyphs render without fallbacks.
font-family = FiraCode Nerd Font
font-size = 14
font-thicken = true

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = auto
window-theme = auto

# Behavior
mouse-hide-while-typing = true
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false
clipboard-paste-bracketed-safe = true

# Shell integration
shell-integration = detect
shell-integration-features = cursor,sudo,title

# Cursor
cursor-style = block
cursor-style-blink = true

# macOS specific
# true = both Option keys send Alt (matches zsh Option+arrow bindkeys)
macos-option-as-alt = true
macos-titlebar-style = tabs

# Keybindings (macOS-friendly)
keybind = cmd+backspace=text:\x15
keybind = opt+backspace=text:\x17
# Form feed = Ctrl+L = zsh clear-screen. Avoid ESC-led sequences (\e[2J…) — ESC toggles vi
# insert/command and flips Starship’s character. vim-tmux: @vim_navigator_mapping_right null.
keybind = cmd+k=text:\x0c
# xterm-style Home/End (CSI 1~ / 4~) — matches tmux-256color khome/kend; SS3 OH/OF is flaky through tmux
keybind = cmd+left=text:\x1b[1~
keybind = cmd+right=text:\x1b[4~
# Same CSI sequences as Option+arrow (see zsh .zshrc bindkey for \e[1;3* )
keybind = super+alt+left=csi:1;3D
keybind = super+alt+right=csi:1;3C
keybind = super+alt+up=csi:1;3A
keybind = super+alt+down=csi:1;3B
keybind = shift+enter=text:\x1b\r

# Tab/Window management (don't conflict with Zellij)
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+n=new_window
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+6=goto_tab:6
keybind = cmd+7=goto_tab:7
keybind = cmd+8=goto_tab:8
keybind = cmd+9=goto_tab:9

# Copy/Paste
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

# Zoom
keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size

# Scrollback
scrollback-limit = 10000

# Link handling
link-url = true

# Background opacity (1.0 = fully opaque, 0.0 = fully transparent)
background-opacity = 1.0
